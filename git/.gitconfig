# This is Git's per-user configuration file.
[user]
    name = REPLACE_NAME
    email = REPLACE_EMAIL
[core]
    excludesfile = ~/.gitignore_global
    editor = vim
[difftool "sourcetree"]
    cmd = opendiff \"$LOCAL\" \"$REMOTE\"
    path =
[mergetool "sourcetree"]
    cmd = /Users/armitage/Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
    trustExitCode = true
[commit]
    template = ~/.stCommitMsg
[push]
    default = current
[pull]
    default = current

[url "https://"]
    insteadOf = git://
[help]
    autoCorrect = 0
[color]
    ui = auto
[init]
    defaultBranch = master
