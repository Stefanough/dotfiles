#  Do not track .DS_Store
*.DS_Store

# Do not track Vim plugins
vim/.vim/bundle/*
.netrwhist

# do not track binary for Vim spellcheck
*.spl

# do not track tmux plugins
tmux/.tmux/plugins/*

# do not track Claude local settings
claude/.claude/**/*.local.*

# do not track Claude cache
claude/.claude/cache/

# do not track Claude backups
claude/.claude/backups/